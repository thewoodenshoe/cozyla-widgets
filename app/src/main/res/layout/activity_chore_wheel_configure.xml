<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/calendar_config_surface"
    android:orientation="vertical"
    android:paddingLeft="24dp"
    android:paddingTop="24dp"
    android:paddingRight="24dp"
    android:paddingBottom="18dp">

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/chore_config_title"
      android:textColor="@color/calendar_config_text"
      android:textSize="24sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:text="@string/chore_config_subtitle"
      android:textColor="@color/calendar_config_secondary"
      android:textSize="15sp" />
  </LinearLayout>

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:fillViewport="true">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:paddingLeft="24dp"
      android:paddingTop="18dp"
      android:paddingRight="24dp"
      android:paddingBottom="18dp">

      <TextView
        android:id="@+id/chore_config_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/calendar_widget_now"
        android:textSize="14sp" />

      <EditText
        android:id="@+id/chore_input_1"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="@string/chore_config_item_hint"
        android:inputType="textCapSentences"
        android:maxLength="32"
        android:singleLine="true" />

      <EditText
        android:id="@+id/chore_input_2"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="@string/chore_config_item_hint"
        android:inputType="textCapSentences"
        android:maxLength="32"
        android:singleLine="true" />

      <EditText
        android:id="@+id/chore_input_3"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="@string/chore_config_item_hint"
        android:inputType="textCapSentences"
        android:maxLength="32"
        android:singleLine="true" />

      <EditText
        android:id="@+id/chore_input_4"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="@string/chore_config_item_hint"
        android:inputType="textCapSentences"
        android:maxLength="32"
        android:singleLine="true" />

      <EditText
        android:id="@+id/chore_input_5"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="@string/chore_config_item_hint"
        android:inputType="textCapSentences"
        android:maxLength="32"
        android:singleLine="true" />

      <EditText
        android:id="@+id/chore_input_6"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="@string/chore_config_item_hint"
        android:inputType="textCapSentences"
        android:maxLength="32"
        android:singleLine="true" />

      <EditText
        android:id="@+id/chore_input_7"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="@string/chore_config_item_hint"
        android:inputType="textCapSentences"
        android:maxLength="32"
        android:singleLine="true" />

      <EditText
        android:id="@+id/chore_input_8"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="@string/chore_config_item_hint"
        android:inputType="textCapSentences"
        android:maxLength="32"
        android:singleLine="true" />
    </LinearLayout>
  </ScrollView>

  <LinearLayout
    style="?android:attr/buttonBarStyle"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@color/calendar_config_surface"
    android:gravity="end|center_vertical"
    android:orientation="horizontal"
    android:paddingLeft="16dp"
    android:paddingRight="16dp">

    <Button
      android:id="@+id/chore_config_cancel"
      style="?android:attr/buttonBarButtonStyle"
      android:layout_width="wrap_content"
      android:layout_height="48dp"
      android:text="@string/chore_config_cancel" />

    <Button
      android:id="@+id/chore_config_save"
      style="?android:attr/buttonBarButtonStyle"
      android:layout_width="wrap_content"
      android:layout_height="48dp"
      android:layout_marginStart="12dp"
      android:text="@string/chore_config_save" />
  </LinearLayout>
</LinearLayout>

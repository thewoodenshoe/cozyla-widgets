<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/calendar_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/calendar_widget_background"
  android:orientation="vertical"
  android:padding="6dp">

  <LinearLayout
    android:id="@+id/calendar_toolbar"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/calendar_previous"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:contentDescription="@string/calendar_widget_previous_week"
      android:padding="12dp"
      android:src="@drawable/ic_calendar_previous" />

    <TextView
      android:id="@+id/calendar_week_label"
      android:layout_width="0dp"
      android:layout_height="48dp"
      android:layout_weight="1"
      android:ellipsize="end"
      android:gravity="center_vertical"
      android:maxLines="1"
      android:paddingLeft="4dp"
      android:paddingRight="4dp"
      android:textColor="@color/calendar_widget_text"
      android:textSize="15sp"
      android:textStyle="bold" />

    <ImageView
      android:id="@+id/calendar_today"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:contentDescription="@string/calendar_widget_today"
      android:padding="12dp"
      android:src="@drawable/ic_calendar_today"
      android:visibility="gone" />

    <ImageView
      android:id="@+id/calendar_refresh"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:contentDescription="@string/calendar_widget_refresh"
      android:padding="12dp"
      android:src="@drawable/ic_calendar_refresh"
      android:visibility="gone" />

    <ImageView
      android:id="@+id/calendar_settings"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:contentDescription="@string/calendar_widget_settings"
      android:padding="12dp"
      android:src="@drawable/ic_calendar_settings"
      android:visibility="gone" />

    <ImageView
      android:id="@+id/calendar_next"
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:contentDescription="@string/calendar_widget_next_week"
      android:padding="12dp"
      android:src="@drawable/ic_calendar_next" />
  </LinearLayout>

  <FrameLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1">

    <LinearLayout

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/countdown_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/countdown_widget_background"
  android:gravity="center_vertical"
  android:orientation="vertical"
  android:padding="12dp">

  <TextView
    android:id="@+id/countdown_status"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:ellipsize="end"
    android:fontFamily="sans"
    android:maxLines="1"
    android:text="@string/countdown_widget_title"
    android:textColor="@color/countdown_secondary"
    android:textSize="11sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/countdown_title"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="3dp"
    android:ellipsize="end"
    android:fontFamily="sans"
    android:maxLines="1"
    android:text="@string/countdown_default_label"
    android:textColor="@color/countdown_text"
    android:textSize="19sp"
    android:textStyle="bold" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="10dp"
    android:layout_weight="1"
    android:baselineAligned="false"
    android:gravity="center"
    android:orientation="horizontal">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:background="@drawable/countdown_value_background"
      android:gravity="center"
      android:orientation="vertical"
      android:padding="5dp">

      <TextView
        android:id="@+id/countdown_days_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:text="0"
        android:textColor="@color/countdown_dark"
        android:textSize="28sp"
        android:textStyle="bold" />

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/countdown_days"
        android:textColor="@color/countdown_dark"
        android:textSize="9sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_marginStart="7dp"
      android:layout_weight="1"
      android:background="@drawable/countdown_value_background"
      android:gravity="center"
      android:orientation="vertical"
      android:padding="5dp">

      <TextView
        android:id="@+id/countdown_hours_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:text="00"
        android:textColor="@color/countdown_dark"
        android:textSize="28sp"
        android:textStyle="bold" />

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/countdown_hours"
        android:textColor="@color/countdown_dark"
        android:textSize="9sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_marginStart="7dp"
      android:layout_weight="1"
      android:background="@drawable/countdown_value_background"
      android:gravity="center"
      android:orientation="vertical"
      android:padding="5dp">

      <TextView
        android:id="@+id/countdown_minutes_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:text="25"
        android:textColor="@color/countdown_dark"
        android:textSize="28sp"
        android:textStyle="bold" />

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/countdown_minutes"
        android:textColor="@color/countdown_dark"
        android:textSize="9sp"
        android:textStyle="bold" />
    </LinearLayout>
  </LinearLayout>
</LinearLayout>
